<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelpDesk.Mobile.LoginPage"
             Title="Login - Help Desk">
    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Label Text="Bem-vindo!" FontSize="24" HorizontalOptions="Center" />
        <Entry x:Name="txtEmail" Placeholder="Digite seu e-mail" Keyboard="Email" />
        <Entry x:Name="txtSenha" Placeholder="Digite sua senha" IsPassword="True" />
        <Button x:Name="btnEntrar" Text="Entrar" Clicked="OnLoginButtonClicked" />
    </VerticalStackLayout>
</ContentPage>