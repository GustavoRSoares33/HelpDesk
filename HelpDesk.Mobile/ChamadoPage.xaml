<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelpDesk.Mobile.ChamadoPage"
             Title="Abrir Chamado">
    <VerticalStackLayout Padding="30" Spacing="20">
        <Label x:Name="lblBoasVindas" FontSize="20" />
        <Label Text="Descreva seu problema abaixo:" />
        <Editor x:Name="txtDescricao" Placeholder="Ex: A impressora não está funcionando..." HeightRequest="200" />
        <Button x:Name="btnAbrirChamado" Text="Abrir Chamado" Clicked="OnAbrirChamadoClicked" />
    </VerticalStackLayout>
</ContentPage>