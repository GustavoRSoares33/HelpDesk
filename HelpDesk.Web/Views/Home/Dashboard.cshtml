@model List<AcessoDados.Models.Chamado>
@{
    ViewData["Title"] = "Meu Painel";
}

<div class="container active" style="width: 80%; max-width: 1200px; text-align: left;">

    <h1 style="text-align: center; margin-bottom: 30px;">Olá, @Context.Session.GetString("NomeUsuario")!</h1>
    <p style="text-align: center;">Aqui você pode registrar um novo chamado ou acompanhar os existentes.</p>
    <a asp-action="MobileView">Ver Simulação Mobile</a>

    <hr style="border-color: #d4af37; margin: 30px 0;" />

    <div class="dashboard-layout">

        <div class="form-column">
    <h3>Registrar Novo Chamado</h3>
    <form method="post" action="@Url.Action("CriarChamado", "Home")">

        <div class="form-group">
            <label for="idCategoria">Categoria:</label>
            <select name="idCategoria" class="form-control" required>
                <option value="">-- Selecione uma categoria --</option>
                        @foreach (var categoria in ViewBag.Categorias)
                        {
                        <option value="@categoria.IdCategoria">@categoria.NomeCategoria</option>
                        }
            </select>
        </div>

        <div class="form-group">
            <label for="descricao">Descreva seu problema:</label>
            <textarea name="descricao" class="form-control" rows="5" placeholder="Ex: Meu computador não está ligando..." required></textarea>
        </div>
        <br />
        <button type="submit" class="btn">Abrir Chamado</button>
    </form>
</div>

        <div class="table-column">
            <h3>Meus Chamados</h3>
            <table class="chamado-table">
                <thead>
                    <tr>
                        <th>Protocolo</th>
                        <th>Descrição</th>
                        <th>Categoria</th> 
                        <th>Data de Abertura</th>
                        <th>Status</th>
                    </tr>
                </thead>
                        <tbody>
                            @foreach (var chamado in Model)
                            {
                    <tr>
                        <td data-label="Protocolo:"><a asp-action="DetalhesChamado" asp-route-id="@chamado.IdChamado">@chamado.IdChamado</a></td>
                        <td data-label="Descrição:">@chamado.Descricao</td>
                        <td data-label="Categoria:">@chamado.NomeCategoria</td>
                        <td data-label="Abertura:">@chamado.DataAbertura.ToString("dd/MM/yyyy HH:mm")</td>
                        <td data-label="Status:">
                                        @if (chamado.Status == "Encerrado" && chamado.Feedback == null)
                                        {
                                            @* O formulário de feedback é muito complexo para o cartão. *@
                                            @* No mobile, vamos apenas mostrar o status. *@
                                    <span>@chamado.Status</span>
                                        }
                                        else
                                        {
                                    <span>@chamado.Status</span>
                                        }
                        </td>
                    </tr>
                            }
        </tbody>
            </table>
        </div>
    </div>
</div>