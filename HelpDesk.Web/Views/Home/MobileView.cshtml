@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    // Diz a esta página para usar o nosso novo layout mobile, e não o layout principal do site.
    Layout = "~/Views/Shared/_MobileLayout.cshtml";
    ViewData["Title"] = "Simulação Mobile";
}

<div class="mobile-simulator-container">
    <div class="mobile-phone-frame">
        <div class="mobile-screen">
            <div class="mobile-app-header">
                <h3>Abrir Chamado</h3>
            </div>

            <div class="mobile-app-content">
                <p>Olá, <strong>@HttpContextAccessor.HttpContext?.Session.GetString("NomeUsuario")</strong>!</p>
                <p>Descreva o seu problema abaixo para abrir um novo chamado.</p>

                <form method="post" action="@Url.Action("CriarChamado", "Home")">
                    <div class="form-group">
                        <label for="idCategoria">Categoria:</label>
                        <select name="idCategoria" class="form-control" required>
                            <option value="">-- Selecione --</option>
                            @* Aqui você precisaria de carregar as categorias, igual ao Dashboard *@
                            <option value="1">Hardware</option>
                            <option value="2">Software</option>
                            <option value="3">Rede</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="descricao">Descrição:</label>
                        <textarea name="descricao" class="form-control" rows="6" placeholder="Ex: A minha impressora não está a funcionar..." required></textarea>
                    </div>

                    <button type="submit" class="btn" style="width: 100%; margin-top: 20px;">Enviar Chamado</button>
                </form>
            </div>
        </div>
    </div>
</div>